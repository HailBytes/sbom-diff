{
  "name": "@hailbytes/sbom-diff",
  "version": "0.0.1",
  "private": true,
  "description": "Diff two CycloneDX or SPDX SBOMs and produce human-readable change reports. Highlights added, removed, upgraded dependencies and new CVEs.",
  "type": "module",
  "license": "MIT",
  "author": "HailBytes, LLC",
  "keywords": [
    "sbom",
    "cyclonedx",
    "spdx",
    "supply-chain-security",
    "dependency-management",
    "cve",
    "vulnerability-management",
    "diff",
    "hailbytes"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/HailBytes/sbom-diff.git"
  },
  "bugs": {
    "url": "https://github.com/HailBytes/sbom-diff/issues"
  },
  "homepage": "https://hailbytes.com",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cli": "node dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "sbom-diff": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "globals": "^17.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}